{
  "schema": "https://tokens.studio/schemas/1.0.0/tokens.json",
  "group": "admin-and-seller",
  "tokens": {
    "font": {
      "family": "Inter, 'Segoe UI', system-ui, sans-serif",
      "weights": {
        "regular": 400,
        "medium": 500,
        "semibold": 600
      }
    },
    "radius": {
      "xs": "6px",
      "sm": "8px",
      "md": "10px",
      "lg": "12px",
      "full": "999px"
    },
    "shadow": {
      "cardLight": "0px 4px 16px rgba(0,0,0,0.08)",
      "cardDark": "0px 4px 16px rgba(0,0,0,0.12)"
    },
    "seller": {
      "background": "#f7f7fb",
      "card": "#ffffff",
      "border": "#e5e7eb",
      "text": {
        "primary": "#111827",
        "secondary": "#6b7280"
      },
      "primary": {
        "bg": "#111827",
        "fg": "#ffffff",
        "hover": "#0f172a"
      },
      "input": {
        "border": "#d1d5db",
        "focus": "#6b7280"
      },
      "status": {
        "shipping": { "bg": "#ede9fe", "fg": "#6b21a8" },
        "confirmed": { "bg": "#dbeafe", "fg": "#1d4ed8" },
        "completed": { "bg": "#ecfdf3", "fg": "#047857" },
        "cancelled": { "bg": "#ffe4e6", "fg": "#be123c" }
      },
      "neutralButton": {
        "border": "#d1d5db",
        "hover": "#f9fafb"
      }
    },
    "admin": {
      "background": {
        "from": "#0f172a",
        "via": "#0b1220",
        "to": "#0f172a"
      },
      "card": "#0f172a",
      "cardAlt": "#111827",
      "border": "#1f2937",
      "text": {
        "primary": "#e5e7eb",
        "secondary": "#9ca3af"
      },
      "accent": {
        "emerald": "#10b981",
        "emeraldHover": "#059669"
      },
      "input": {
        "bg": "#0b1220",
        "border": "#1f2937",
        "focus": "#10b981"
      },
      "badge": {
        "success": "#10b981",
        "warning": "#f59e0b",
        "info": "#38bdf8",
        "default": "#94a3b8"
      }
    },
    "layout": {
      "cardPadding": "16px",
      "gap": "8px",
      "gapLg": "12px",
      "lineHeight": "1.5"
    }
  }
}
